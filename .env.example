# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/homeimprovepk

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme-use-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ─── OTP ────────────────────────────────────────────────────────────────────
# true in development → OTP code is always "123456"
OTP_STUB=true
OTP_EXPIRY_MINUTES=10

# ─── Twilio SMS ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Payments ───────────────────────────────────────────────────────────────
# true in development → payments return a stubbed success response
JAZZCASH_STUB=true
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=

EASYPAISA_STUB=true
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── CORS ───────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
